<mujoco>
  <include file="world.xml"/>
  <worldbody>
    

    <!-- directional light -->
    <light pos="0 0 3" dir="0 0 -1"/>

    <!-- Box 1 (purple)  -->
    <body name="purple-box" pos="1 0 1.5">
      <freejoint/>
      <geom type="box" size="0.05 0.05 0.1" rgba="0.8 0.2 0.8 1"/>
    </body>

    <!-- Box 2 (yellow) -->
    <body name="yellow-box" pos="0.7 0.2 1.5">
      <freejoint/>
      <geom type="box" size="0.05 0.05 0.05" rgba="0.8 0.9 0.3 0.5"/>
    </body>

    <!-- Sphere (cyan) -->
    <body name="cyan-sphere" pos="0.7 -0.2 1.5">
      <freejoint/>
      <geom type="sphere" size="0.05" rgba="0.3 0.9 0.9 0.5"/>
    </body>


    <!-- The ground -->
    <geom name="playground_floor" type="plane" size="10 10 0.1" rgba="0.5 0.5 0.5 1"/>
  </worldbody>
</mujoco>